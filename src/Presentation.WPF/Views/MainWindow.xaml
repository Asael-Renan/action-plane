<Window x:Class="Presentation.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Presentation.WPF.Converters"
        Title="5W2H Task Management System" 
        Height="700" 
        Width="1200"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:DateTimeToStringConverter x:Key="DateTimeToStringConverter"/>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <local:PriorityColorConverter x:Key="PriorityColorConverter"/>
        <local:WidthConverter x:Key="WidthConverter"/>
    </Window.Resources>
    
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Padding="20,15">
            <Grid>
                <TextBlock FontSize="24" FontWeight="Bold" Foreground="White">📋 5W2H Task Management</TextBlock>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}" Padding="10" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Width="150" Height="4" IsIndeterminate="{Binding IsLoading}" 
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                             Foreground="{StaticResource SuccessBrush}" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Filter Panel (Left Sidebar) -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}" Padding="15,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0">
                        <TextBlock Text="🔍 Filtros" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>

                        <!-- Search -->
                        <TextBlock Text="Buscar" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10" Height="38" Margin="0,0,0,15"
                                 Style="{StaticResource {x:Type TextBox}}"/>

                        <!-- Start Date -->
                        <TextBlock Text="Data Inicial" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding FilterStartDate}"
                                    Padding="10" Height="38" Margin="0,0,0,15"
                                    Style="{StaticResource {x:Type DatePicker}}"/>

                        <!-- End Date -->
                        <TextBlock Text="Data Final" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding FilterEndDate}"
                                    Padding="10" Height="38" Margin="0,0,0,15"
                                    Style="{StaticResource {x:Type DatePicker}}"/>

                        <!-- Responsible -->
                        <TextBlock Text="Responsável" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FilterResponsible, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10" Height="38" Margin="0,0,0,20"
                                 Style="{StaticResource {x:Type TextBox}}"/>

                        <!-- Buttons -->
                        <Button Command="{Binding SearchTasksCommand}" 
                                Content="🔎 Buscar" 
                                Padding="12,10" 
                                Background="{StaticResource PrimaryBrush}" 
                                Foreground="White" 
                                FontWeight="Bold"
                                Margin="0,0,0,8"/>
                        <Button Command="{Binding ResetFiltersCommand}" 
                                Content="↺ Limpar" 
                                Padding="12,10" 
                                Background="#9E9E9E" 
                                Foreground="White" 
                                FontWeight="Bold"
                                Margin="0,0,0,8"/>
                        <Button Command="{Binding LoadTasksCommand}" 
                                Content="🔄 Atualizar" 
                                Padding="12,10" 
                                Background="{StaticResource SuccessBrush}" 
                                Foreground="White" 
                                FontWeight="Bold"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Tasks Area (Right Side) -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="20">
                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Vertical" Margin="0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" 
                                    BorderBrush="{StaticResource BorderBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="8" 
                                    Padding="16" 
                                    Margin="0,0,0,12"
                                    Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- ID Badge -->
                                    <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" 
                                            Background="{StaticResource PrimaryBrush}" 
                                            CornerRadius="4" 
                                            Padding="10,5" 
                                            Margin="0,0,12,0" 
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Id, StringFormat=\#00000}" 
                                                   Foreground="White" 
                                                   FontWeight="Bold" 
                                                   FontSize="14"/>
                                    </Border>

                                    <!-- Main Content -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding What}" 
                                                   FontSize="15" 
                                                   FontWeight="Bold" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   TextWrapping="Wrap" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Why}" 
                                                   FontSize="12" 
                                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <Border Grid.Row="0" Grid.Column="2" 
                                            Background="{Binding Status, Converter={StaticResource StatusColorConverter}}" 
                                            CornerRadius="4" 
                                            Padding="8,4" 
                                            Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Status}" 
                                                   Foreground="White" 
                                                   FontSize="11" 
                                                   FontWeight="Bold" 
                                                   TextAlignment="Center"/>
                                    </Border>

                                    <!-- Details -->
                                    <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="👤 Quem" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Who}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                            <TextBlock Text="📅 Quando" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding When, Converter={StaticResource DateTimeToStringConverter}}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                            <TextBlock Text="📍 Onde" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Where}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="💰 Custo" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding HowMuch, StringFormat=C}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Footer -->
                                    <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="{Binding How}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                        
                                        <Border Grid.Column="1" 
                                                Background="{Binding Priority, Converter={StaticResource PriorityColorConverter}}" 
                                                CornerRadius="4" 
                                                Padding="6,3" 
                                                Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Priority}" 
                                                       Foreground="White" 
                                                       FontSize="10" 
                                                       FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>