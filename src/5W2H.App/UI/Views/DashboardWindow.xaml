<Window x:Class="_5W2H.App.UI.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Dashboard - 5W2H Task Management" 
        Height="800" 
        Width="1400"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Padding="20,15">
            <Grid>
                <TextBlock FontSize="24" FontWeight="Bold" Foreground="White">📊 Dashboard &amp; Análise</TextBlock>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Background="{StaticResource BackgroundBrush}" Padding="20,20,20,20">
            <StackPanel>
                
                <!-- Summary Cards Row -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Tasks Card -->
                    <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="8" Padding="20" Margin="0,0,10,0" 
                            BorderBrush="#E8EEF5" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📋 Total de Tarefas" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TotalTasks}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Completed Card -->
                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="8" Padding="20" Margin="0,0,10,0"
                            BorderBrush="#E8F5E9" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="✅ Completas" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CompletedTasks}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- In Progress Card -->
                    <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="8" Padding="20" Margin="0,0,10,0"
                            BorderBrush="#FFF3E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="⏳ Em Progresso" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding InProgressTasks}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Pending Card -->
                    <Border Grid.Column="3" Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="8" Padding="20" Margin="0,0,10,0"
                            BorderBrush="#FFEBEE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="⏸️ Pendentes" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding PendingTasks}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Cost Card -->
                    <Border Grid.Column="4" Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="8" Padding="20"
                            BorderBrush="#F3E5F5" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="💰 Custo Total" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TotalCost, StringFormat=C}" FontSize="32" FontWeight="Bold" Foreground="#7B1FA2"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Charts Row 1 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status Distribution - Pie Chart -->
                    <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="8" Padding="20" Margin="0,0,10,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📊 Status das Tarefas" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>
                            <oxy:PlotView Model="{Binding StatusChartModel}" Height="250" Background="Transparent"/>
                        </StackPanel>
                    </Border>

                    <!-- Priority Distribution - Pie Chart -->
                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="8" Padding="20"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="⚡ Prioridade das Tarefas" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>
                            <oxy:PlotView Model="{Binding PriorityChartModel}" Height="250" Background="Transparent"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Charts Row 2 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cost by Priority - Bar Chart -->
                    <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="8" Padding="20" Margin="0,0,10,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="💵 Custo por Prioridade" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>
                            <oxy:PlotView Model="{Binding CostChartModel}" Height="250" Background="Transparent"/>
                        </StackPanel>
                    </Border>

                    <!-- Tasks Over Time - Line Chart -->
                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="8" Padding="20"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📈 Tarefas ao Longo do Tempo" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>
                            <oxy:PlotView Model="{Binding TrendChartModel}" Height="250" Background="Transparent"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Action Button -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Command="{Binding LoadDashboardCommand}"
                            Content="🔄 Atualizar Dashboard" 
                            Padding="20,12" 
                            Background="{StaticResource PrimaryBrush}" 
                            Foreground="White" 
                            FontWeight="Bold"
                            FontSize="13"/>
                </StackPanel>
                </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
