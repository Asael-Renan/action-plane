<Window x:Class="_5W2H.App.UI.Views.EditItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar registro"
        Width="760"
        Height="620"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PrimaryBrush}"
                Padding="22,18">
            <StackPanel>
                <TextBlock Text="Editar registro 5W2H"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="{Binding Id, StringFormat=Registro #{0:00000}}"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#DDEEFF"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationSummary}"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding CancelCommand}"
                            Content="Cancelar"
                            Background="#90A4AE"
                            Foreground="White"
                            Padding="18,10"
                            Margin="0,0,10,0"/>
                    <Button Command="{Binding SaveCommand}"
                            Content="Salvar"
                            Background="{StaticResource SuccessBrush}"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="22,10"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="What" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding What, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                 Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Who" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Who, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                 Height="40"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Why" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Why, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                 Height="92"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="How" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding How, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                 Height="92"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Where" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Where, UpdateSourceTrigger=PropertyChanged}"
                                 Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                        <TextBlock Text="When" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding When, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                    Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                        <TextBlock Text="How Much" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding HowMuch, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, StringFormat=N2}"
                                 Height="40"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Status" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Statuses}"
                                  SelectedItem="{Binding SelectedStatus}"
                                  Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                        <TextBlock Text="Priority" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Priorities}"
                                  SelectedItem="{Binding SelectedPriority}"
                                  Height="40"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="Detalhes adicionais" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Height="90"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
