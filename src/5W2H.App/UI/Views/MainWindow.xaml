<Window x:Class="_5W2H.App.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:_5W2H.App.UI.Converters"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="5W2H Task Management System"
        Height="760"
        Width="1320"
        MinHeight="720"
        MinWidth="1180"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:DateTimeToStringConverter x:Key="DateTimeToStringConverter"/>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <local:PriorityColorConverter x:Key="PriorityColorConverter"/>
        <local:WidthConverter x:Key="WidthConverter"/>

        <Style x:Key="ReadableDataGridStyle" TargetType="{x:Type DataGrid}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="RowHeight" Value="46"/>
            <Setter Property="MinRowHeight" Value="46"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FBFE"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="ReadableDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="#1565C0"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

        <Style x:Key="ReadableDataGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReadableDataGridRowStyle" TargetType="{x:Type DataGridRow}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF7FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D7ECFF"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridTextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ChartCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FAFCFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="White" Text="5W2H Management"/>
                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#DDEEFF"
                               Text="Cadastre planos de acao e consulte os registros com filtros rapidos."/>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding OpenFilterScreenCommand}"
                        Content="Ir para consulta"
                        Padding="18,10"
                        Margin="12,0,0,0"
                        Background="#FFFFFF"
                        Foreground="{StaticResource PrimaryBrush}"
                        FontWeight="Bold"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}" Padding="10" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Width="160" Height="4" IsIndeterminate="{Binding IsLoading}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                             Foreground="{StaticResource SuccessBrush}" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <Grid Background="{StaticResource BackgroundBrush}">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="20">
                <TabItem Header="Cadastro 5W2H">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,16,0,0" Grid.IsSharedSizeScope="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.1*"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="24"
                                    Margin="0,0,16,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                        <TextBlock Text="Novo plano de acao" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Margin="0,6,0,0" Text="Preencha os 5W2H principais, prioridade e observacoes para registrar a atividade."
                                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Grid Grid.Row="1" Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Top">
                                            <TextBlock Text="What" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding NewWhat, UpdateSourceTrigger=PropertyChanged}" Height="40"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                                            <TextBlock Text="Who" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding NewWho, UpdateSourceTrigger=PropertyChanged}" Height="40"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="2" Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Top">
                                            <TextBlock Text="Why" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding NewWhy, UpdateSourceTrigger=PropertyChanged}" Height="90" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                                            <TextBlock Text="How" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding NewHow, UpdateSourceTrigger=PropertyChanged}" Height="90" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="3" Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Top">
                                            <TextBlock Text="Where" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding NewWhere, UpdateSourceTrigger=PropertyChanged}" Height="40"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Top">
                                            <TextBlock Text="When" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                            <DatePicker SelectedDate="{Binding NewWhen}" Height="40"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Top">
                                            <TextBlock Text="How Much" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding NewHowMuch, UpdateSourceTrigger=PropertyChanged}" Height="40"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="4" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Top">
                                            <TextBlock Text="Priority" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                            <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding SelectedPriority}" Height="40"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                            <TextBlock Text="Notes" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}" Height="96" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Command="{Binding ClearCreateFormCommand}"
                                                Content="Limpar formulario"
                                                Background="#90A4AE"
                                                Foreground="White"
                                                Padding="18,10"
                                                Margin="0,0,10,0"/>
                                        <Button Command="{Binding CreateTaskCommand}"
                                                Content="Salvar cadastro"
                                                Background="{StaticResource SuccessBrush}"
                                                Foreground="White"
                                                Padding="20,10"
                                                FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                <Border Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="22"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Resumo do cadastro" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Margin="0,12,0,0" Text="A tela registra os 5W2H completos com data, custo, prioridade e observacoes."
                                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Margin="0,10,0,0" Text="Campos essenciais: What, Why, Who, How e When."
                                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Margin="0,10,0,0" Text="Ao salvar, o app volta para a consulta com a lista atualizada."
                                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="22">
                                    <StackPanel>
                                        <TextBlock Text="Dados atuais do formulario" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <Border Margin="0,14,0,0" Padding="14" CornerRadius="6" Background="#F7FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{Binding NewWhat}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Margin="0,8,0,0" Text="{Binding NewWhy}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Margin="0,12,0,0" Text="{Binding NewHow}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="Responsavel" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding NewWho}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="Local" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding NewWhere}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="Entrega" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding NewWhen, Converter={StaticResource DateTimeToStringConverter}}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="Prioridade" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <Border Margin="0,4,0,0" Padding="8,4" CornerRadius="4" Background="{Binding SelectedPriority, Converter={StaticResource PriorityColorConverter}}" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding SelectedPriority}" Foreground="White" FontWeight="Bold" FontSize="11"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Consulta e filtros">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="310"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8" Padding="18" Margin="0,0,18,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Localizar registros" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Combine palavras-chave, periodo, responsavel e classificacoes." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,18" TextWrapping="Wrap"/>

                                    <TextBlock Text="Buscar" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="40" Margin="0,0,0,14"/>

                                    <TextBlock Text="Data inicial" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                    <DatePicker SelectedDate="{Binding FilterStartDate}" Height="40" Margin="0,0,0,14"/>

                                    <TextBlock Text="Data final" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                    <DatePicker SelectedDate="{Binding FilterEndDate}" Height="40" Margin="0,0,0,14"/>

                                    <TextBlock Text="Responsavel" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding FilterResponsible, UpdateSourceTrigger=PropertyChanged}" Height="40" Margin="0,0,0,14"/>

                                    <TextBlock Text="Status" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding FilterStatus}" Height="40" Margin="0,0,0,14"/>

                                    <TextBlock Text="Prioridade" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding FilterPriority}" Height="40" Margin="0,0,0,20"/>

                                    <Button Command="{Binding SearchTasksCommand}"
                                            Content="Aplicar filtros"
                                            Padding="12,10"
                                            Background="{StaticResource PrimaryBrush}"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Margin="0,0,0,8"
                                            HorizontalAlignment="Stretch"/>
                                    <Button Command="{Binding ResetFiltersCommand}"
                                            Content="Limpar filtros"
                                            Padding="12,10"
                                            Background="#90A4AE"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Margin="0,0,0,8"
                                            HorizontalAlignment="Stretch"/>
                                    <Button Command="{Binding LoadTasksCommand}"
                                            Content="Atualizar lista"
                                            Padding="12,10"
                                            Background="{StaticResource SuccessBrush}"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Margin="0,0,0,8"
                                            HorizontalAlignment="Stretch"/>
                                    <Button Command="{Binding DeleteSelectedTaskCommand}"
                                            Content="Excluir selecionado"
                                            Padding="12,10"
                                            Background="{StaticResource DangerBrush}"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="320"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Registros cadastrados" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Tasks.Count, StringFormat={}{0} item(ns) exibido(s)}" Margin="0,5,0,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Background="#E3F2FD"
                                            BorderBrush="#BBDEFB"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="14,8"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Stretch">
                                        <TextBlock Text="{Binding SelectedTask.What, TargetNullValue=Nenhum item selecionado}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="1"
                                        Background="#F7FAFC"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10"
                                        Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Command="{Binding OpenCreateScreenCommand}"
                                                    Content="Adicionar"
                                                    Background="{StaticResource PrimaryBrush}"
                                                    Foreground="White"
                                                    FontWeight="Bold"
                                                    Padding="14,8"
                                                    Margin="0,0,8,0"/>
                                            <Button Command="{Binding EditSelectedTaskCommand}"
                                                    Content="Editar"
                                                    Background="{StaticResource InfoBrush}"
                                                    Foreground="White"
                                                    FontWeight="Bold"
                                                    Padding="14,8"
                                                    Margin="0,0,8,0"/>
                                            <Button Command="{Binding DeleteSelectedTaskCommand}"
                                                    Content="Excluir"
                                                    Background="{StaticResource DangerBrush}"
                                                    Foreground="White"
                                                    FontWeight="Bold"
                                                    Padding="14,8"
                                                    Margin="0,0,8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right">
                                            <Button Command="{Binding ImportDataCommand}"
                                                    Content="Importar dados"
                                                    Background="#607D8B"
                                                    Foreground="White"
                                                    FontWeight="Bold"
                                                    Padding="14,8"
                                                    Margin="0,0,8,0"/>
                                            <Button Command="{Binding ExportDataCommand}"
                                                    Content="Exportar dados"
                                                    Background="{StaticResource SuccessBrush}"
                                                    Foreground="White"
                                                    FontWeight="Bold"
                                                    Padding="14,8"
                                                    Margin="0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.8*" MinWidth="620"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="1*" MinWidth="280" MaxWidth="360"/>
                                    </Grid.ColumnDefinitions>

                                    <DataGrid Grid.Column="0"
                                              ItemsSource="{Binding Tasks}"
                                              SelectedItem="{Binding SelectedTask}"
                                              Style="{StaticResource ReadableDataGridStyle}"
                                              ColumnHeaderStyle="{StaticResource ReadableDataGridHeaderStyle}"
                                              CellStyle="{StaticResource ReadableDataGridCellStyle}"
                                              RowStyle="{StaticResource ReadableDataGridRowStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID"
                                                                Binding="{Binding Id, StringFormat=\#00000}"
                                                                Width="Auto"
                                                                ElementStyle="{StaticResource GridTextBlockStyle}"/>
                                            <DataGridTextColumn Header="What"
                                                                Binding="{Binding What}"
                                                                Width="1.7*"
                                                                MinWidth="190"
                                                                ElementStyle="{StaticResource GridTextBlockStyle}"/>
                                            <DataGridTextColumn Header="Who"
                                                                Binding="{Binding Who}"
                                                                Width="*"
                                                                MinWidth="120"
                                                                ElementStyle="{StaticResource GridTextBlockStyle}"/>
                                            <DataGridTextColumn Header="When"
                                                                Binding="{Binding When, StringFormat={}{0:dd/MM/yyyy}}"
                                                                Width="Auto"
                                                                ElementStyle="{StaticResource GridTextBlockStyle}"/>
                                            <DataGridTextColumn Header="Where"
                                                                Binding="{Binding Where}"
                                                                Width="*"
                                                                MinWidth="120"
                                                                ElementStyle="{StaticResource GridTextBlockStyle}"/>
                                            <DataGridTemplateColumn Header="Status" Width="Auto" MinWidth="110">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                                                CornerRadius="4"
                                                                Padding="9,4"
                                                                HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding Status}"
                                                                       Foreground="White"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Priority" Width="Auto" MinWidth="105">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{Binding Priority, Converter={StaticResource PriorityColorConverter}}"
                                                                CornerRadius="4"
                                                                Padding="9,4"
                                                                HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding Priority}"
                                                                       Foreground="White"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Cost"
                                                                Binding="{Binding HowMuch, StringFormat=C}"
                                                                Width="Auto"
                                                                ElementStyle="{StaticResource GridTextBlockStyle}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Style="{StaticResource ChartCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Status" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                <oxy:PlotView Grid.Row="1" Model="{Binding StatusChartModel}" MinHeight="92" Background="Transparent"/>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Row="2" Style="{StaticResource ChartCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Prioridade" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                <oxy:PlotView Grid.Row="1" Model="{Binding PriorityChartModel}" MinHeight="92" Background="Transparent"/>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Row="4" Style="{StaticResource ChartCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Top responsaveis" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                <oxy:PlotView Grid.Row="1" Model="{Binding ResponsibleChartModel}" MinHeight="92" Background="Transparent"/>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Row="6" Style="{StaticResource ChartCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Cronograma" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                <oxy:PlotView Grid.Row="1" Model="{Binding TimelineChartModel}" MinHeight="92" Background="Transparent"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
