<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryColor">#1D4ED8</Color>
    <Color x:Key="PrimaryDarkColor">#1E40AF</Color>
    <Color x:Key="PrimaryAccentColor">#2563EB</Color>
    <Color x:Key="AccentColor">#EF4444</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="DangerColor">#DC2626</Color>
    <Color x:Key="InfoColor">#0284C7</Color>
    <Color x:Key="BackgroundColor">#F1F5F9</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceRaisedColor">#F8FAFC</Color>
    <Color x:Key="SurfaceMutedColor">#E2E8F0</Color>
    <Color x:Key="InputSurfaceColor">#FFFFFF</Color>
    <Color x:Key="TextPrimaryColor">#0F172A</Color>
    <Color x:Key="TextSecondaryColor">#475569</Color>
    <Color x:Key="TextMutedColor">#94A3B8</Color>
    <Color x:Key="BorderColor">#CBD5E1</Color>
    <Color x:Key="DisabledColor">#94A3B8</Color>
    <Color x:Key="PendingAccentColor">#D97706</Color>
    <Color x:Key="CompletedAccentColor">#16A34A</Color>
    <Color x:Key="CostAccentColor">#6D28D9</Color>
    <Color x:Key="CriticalSurfaceColor">#FEF2F2</Color>
    <Color x:Key="CriticalBorderColor">#FECACA</Color>
    <Color x:Key="CriticalTextColor">#B91C1C</Color>
    <Color x:Key="DataGridRowHoverColor">#E8EEF5</Color>
    <Color x:Key="DataGridRowSelectedColor">#DBEAFE</Color>
    <Color x:Key="ChartTextColor">#0F172A</Color>
    <Color x:Key="ChartAxisTextColor">#64748B</Color>
    <Color x:Key="ChartEmptySliceColor">#CBD5E1</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource SurfaceMutedColor}"/>
    <SolidColorBrush x:Key="InputSurfaceBrush" Color="{StaticResource InputSurfaceColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource DisabledColor}"/>
    <SolidColorBrush x:Key="PendingAccentBrush" Color="{StaticResource PendingAccentColor}"/>
    <SolidColorBrush x:Key="CompletedAccentBrush" Color="{StaticResource CompletedAccentColor}"/>
    <SolidColorBrush x:Key="CostAccentBrush" Color="{StaticResource CostAccentColor}"/>
    <SolidColorBrush x:Key="CriticalSurfaceBrush" Color="{StaticResource CriticalSurfaceColor}"/>
    <SolidColorBrush x:Key="CriticalBorderBrush" Color="{StaticResource CriticalBorderColor}"/>
    <SolidColorBrush x:Key="CriticalTextBrush" Color="{StaticResource CriticalTextColor}"/>
    <SolidColorBrush x:Key="DataGridRowHoverBrush" Color="{StaticResource DataGridRowHoverColor}"/>
    <SolidColorBrush x:Key="DataGridRowSelectedBrush" Color="{StaticResource DataGridRowSelectedColor}"/>

</ResourceDictionary>
