<UserControl x:Class="FiveW2H.App.UI.Views.Sections.CreateTaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:FiveW2H.App.UI.Views.Components"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid Margin="{StaticResource PagePadding}">
        <Border Style="{StaticResource WorkspaceHeaderCardStyle}"
                Padding="0"
                CornerRadius="{StaticResource CornerRadiusLarge}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="24,22,24,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Nova Acao"
                                   Style="{StaticResource PageTitleTextStyle}"/>
                        <TextBlock Text="Preencha os campos principais do plano 5W2H para registrar uma nova iniciativa."
                                   Margin="0,8,0,0"
                                   Style="{StaticResource PageSubtitleTextStyle}"/>
                        <Border Style="{StaticResource ChipBadgeStyle}"
                                HorizontalAlignment="Left"
                                Margin="0,18,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CircleSmall"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="-4,0,4,0"
                                                         Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                <TextBlock Text="Rascunho • salvamento manual"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding OpenFilterScreenCommand}"
                            Content="← Voltar para Acoes"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            VerticalAlignment="Top"/>
                </Grid>

                <Border Grid.Row="1"
                        Background="{DynamicResource BorderBrush}"/>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,20,22,18">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="O QUE"
                                           Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource WrappingTextBoxStyle}"
                                         Text="{Binding NewWhat, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="EMPRESA"
                                           Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource WrappingTextBoxStyle}"
                                         Text="{Binding NewCompany, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4"
                                        Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="QUEM"
                                           Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource WrappingTextBoxStyle}"
                                         Text="{Binding NewWho, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="POR QUE"
                                           Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                                         Text="{Binding NewWhy, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="COMO"
                                           Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                                         Text="{Binding NewHow, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.35*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="1.35*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="2.55*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="ONDE"
                                           Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource WrappingTextBoxStyle}"
                                         Text="{Binding NewWhere, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="QUANDO"
                                           Style="{StaticResource FormLabelStyle}"/>
                                <DatePicker MinWidth="0"
                                            SelectedDate="{Binding NewWhen}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4"
                                        Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="CUSTO"
                                           Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding NewHowMuch, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="6"
                                        Style="{StaticResource FormFieldContainerStyle}">
                                <components:PrioritySelector ItemsSource="{Binding Priorities}"
                                                             SelectedItem="{Binding SelectedPriority}"
                                                             Label="PRIORIDADE"
                                                             Hint=""/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                            <TextBlock Text="OBSERVACOES"
                                       Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                                     MinHeight="90"
                                     Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="3"
                        Background="{DynamicResource BorderBrush}"/>

                <Grid Grid.Row="4" Margin="24,16,24,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Dica: revise campos obrigatorios antes de salvar."
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Command="{Binding ClearCreateFormCommand}"
                                Content="Limpar"
                                Style="{StaticResource TertiaryActionButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Command="{Binding CreateTaskCommand}"
                                Content="Salvar Acao"
                                Style="{StaticResource PrimaryActionButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
