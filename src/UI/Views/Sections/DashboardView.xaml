<UserControl x:Class="FiveW2H.App.UI.Views.Sections.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource PagePadding}">
            <Border Style="{StaticResource WorkspaceHeaderCardStyle}"
                    Margin="{StaticResource HeaderSpacing}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Dashboard" Style="{StaticResource PageTitleTextStyle}"/>
                        <TextBlock Text="Visao geral do seu plano de acao 5W2H"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource PageSubtitleTextStyle}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding RefreshTasksCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh"
                                                     Width="16"
                                                     Height="16"
                                                     Margin="0,0,8,0"/>
                            <TextBlock Text="Atualizar dados" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Margin="{StaticResource SectionSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource MetricCardStyle}" BorderBrush="{DynamicResource PrimaryAccentBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="TOTAL DE ACOES" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding TotalActions}" Style="{StaticResource MetricValueTextStyle}"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="40"
                                Height="40"
                                CornerRadius="12"
                                Background="{DynamicResource PrimaryBrush}"
                                VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="ClipboardTextOutline"
                                                     Width="18"
                                                     Height="18"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" BorderBrush="{DynamicResource PendingAccentBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="PENDENTES" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding PendingActions}" Style="{StaticResource MetricValueTextStyle}"/>
                            <TextBlock Text="{Binding PendingPercentText}"
                                       Margin="0,5,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="40"
                                Height="40"
                                CornerRadius="12"
                                Background="{DynamicResource PendingAccentBrush}"
                                VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="ClockOutline"
                                                     Width="18"
                                                     Height="18"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource MetricCardStyle}" BorderBrush="{DynamicResource CompletedAccentBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="CONCLUIDAS" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding CompletedActions}" Style="{StaticResource MetricValueTextStyle}"/>
                            <TextBlock Text="{Binding CompletedPercentText}"
                                       Margin="0,5,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="40"
                                Height="40"
                                CornerRadius="12"
                                Background="{DynamicResource CompletedAccentBrush}"
                                VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                     Width="18"
                                                     Height="18"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource MetricCardStyle}" BorderBrush="{DynamicResource CostAccentBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="CUSTO TOTAL" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding TotalCost, StringFormat=R$ {0:N2}}"
                                       Margin="0,5,0,0"
                                       FontSize="25"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="40"
                                Height="40"
                                CornerRadius="12"
                                Background="{DynamicResource CostAccentBrush}"
                                VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="CashMultiple"
                                                     Width="18"
                                                     Height="18"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Style="{StaticResource AlertCardStyle}"
                    Margin="{StaticResource SectionSpacing}"
                    Visibility="{Binding HasCriticalPendingActions, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                             Width="18"
                                             Height="18"
                                             Foreground="{DynamicResource CriticalTextBrush}"
                                             Margin="0,0,13,0"/>
                    <TextBlock Text="{Binding CriticalPendingActions, StringFormat={}{0} acoes criticas pendentes de conclusao.}"
                               Foreground="{DynamicResource CriticalTextBrush}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource ChartCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Status das Acoes" Style="{StaticResource ChartHeadingStyle}"/>
                        <oxy:PlotView Grid.Row="1" Model="{Binding StatusChartModel}" Background="Transparent"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ChartCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Volume por Empresa" Style="{StaticResource ChartHeadingStyle}"/>
                        <oxy:PlotView Grid.Row="1" Model="{Binding CompanyDistributionChartModel}" Background="Transparent"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource ChartCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Custo por Empresa" Style="{StaticResource ChartHeadingStyle}"/>
                        <oxy:PlotView Grid.Row="1" Model="{Binding CompanyCostChartModel}" Background="Transparent"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource ChartCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Prazos por Mes" Style="{StaticResource ChartHeadingStyle}"/>
                        <oxy:PlotView Grid.Row="1" Model="{Binding TimelineChartModel}" Background="Transparent"/>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
