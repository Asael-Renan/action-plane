<UserControl x:Class="FiveW2H.App.UI.Views.Sections.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:FiveW2H.App.UI.Helpers"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource WorkspaceHeaderCardStyle}">
            <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Acoes"
                               Style="{StaticResource PageTitleTextStyle}"
                               VerticalAlignment="Center"/>

                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <Border Style="{StaticResource FilterChipStyle}"
                                Padding="8,4"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FormatListChecks"
                                                         Width="12"
                                                         Height="12"
                                                         Margin="0,0,5,0"
                                                         Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                <TextBlock Text="{Binding Tasks.Count, StringFormat={}{0} registros}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource FilterChipStyle}"
                                Padding="8,4"
                                Margin="0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderMoveOutline"
                                                         Width="12"
                                                         Height="12"
                                                         Margin="0,0,5,0"
                                                         Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                <TextBlock Text="{Binding SelectedGroupingLabel}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Command="{Binding RefreshTasksCommand}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="Atualizar lista"
                            Margin="0,0,10,0">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding ExportDataCommand}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="Exportar planilha"
                            Margin="0,0,10,0">
                        <materialDesign:PackIcon Kind="TrayArrowUp" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding ImportDataCommand}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="Importar planilha"
                            Margin="0,0,10,0">
                        <materialDesign:PackIcon Kind="TrayArrowDown" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding OpenCreateTaskDialogCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PlusCircleOutline"
                                                     Width="16"
                                                     Height="16"
                                                     Margin="0,0,8,0"/>
                            <TextBlock Text="Nova Acao" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource FormCardStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="1.1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="BUSCA" Style="{StaticResource FilterCaptionTextStyle}"/>
                        <Grid>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="{StaticResource CompactControlHeight}"
                                     Padding="14,5,12,5"
                                     VerticalContentAlignment="Center"/>
                            <materialDesign:PackIcon Kind="Magnify"
                                                     Width="15"
                                                     Height="15"
                                                     Foreground="{DynamicResource TextMutedBrush}"
                                                     Margin="12,0,0,0"
                                                     VerticalAlignment="Center"
                                                     HorizontalAlignment="Left"/>
                            <TextBlock Text="Buscar por acao, empresa, responsavel ou observacao"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="34,0,0,0"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="EMPRESA" Style="{StaticResource FilterCaptionTextStyle}"/>
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding CompanyOptions}"
                                  Text="{Binding FilterCompany, UpdateSourceTrigger=PropertyChanged}"
                                  Width="Auto"
                                  Tag="Todas empresas"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="RESPONSAVEL" Style="{StaticResource FilterCaptionTextStyle}"/>
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding ResponsibleOptions}"
                                  Text="{Binding FilterResponsible, UpdateSourceTrigger=PropertyChanged}"
                                  Width="Auto"
                                  Tag="Todos responsaveis"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="AGRUPAMENTO" Style="{StaticResource FilterCaptionTextStyle}"/>
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding GroupingOptions}"
                                  helpers:ComboBoxAutoComplete.IsEnabled="False"
                                  SelectedItem="{Binding SelectedGrouping}"
                                  DisplayMemberPath="Label"
                                  Width="Auto"
                                  Tag="Agrupamento"/>
                    </StackPanel>
                </Grid>

                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="1.15*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="DE" Style="{StaticResource FilterCaptionTextStyle}"/>
                        <DatePicker SelectedDate="{Binding FilterStartDate}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ATE" Style="{StaticResource FilterCaptionTextStyle}"/>
                        <DatePicker SelectedDate="{Binding FilterEndDate}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="STATUS" Style="{StaticResource FilterCaptionTextStyle}"/>
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding Statuses}"
                                  helpers:ComboBoxAutoComplete.IsEnabled="False"
                                  ItemTemplate="{StaticResource EnumComboBoxItemTemplate}"
                                  SelectedItem="{Binding FilterStatus}"
                                  Width="Auto"
                                  Tag="Todos status"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="PRIORIDADE" Style="{StaticResource FilterCaptionTextStyle}"/>
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding Priorities}"
                                  helpers:ComboBoxAutoComplete.IsEnabled="False"
                                  ItemTemplate="{StaticResource EnumComboBoxItemTemplate}"
                                  SelectedItem="{Binding FilterPriority}"
                                  Width="Auto"
                                  Tag="Todas prioridades"/>
                    </StackPanel>
                    <Button Grid.Column="8"
                            Command="{Binding SearchTasksCommand}"
                            Content="Aplicar filtros"
                            Style="{StaticResource FilterActionButtonStyle}"/>
                    <Button Grid.Column="10"
                            Command="{Binding ResetFiltersCommand}"
                            Content="Limpar"
                            Style="{StaticResource FilterSecondaryActionButtonStyle}"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                Background="{DynamicResource BorderBrush}"
                BorderThickness="0"
                CornerRadius="{DynamicResource CornerRadiusLarge}"
                Padding="1">
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="{DynamicResource CornerRadiusLarge}"
                    ClipToBounds="True">
            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource SurfaceRaisedBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="13,13,0,0"
                        Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="RESULTADOS" Style="{StaticResource SectionHeadingStyle}"/>
                            <TextBlock Text="{Binding Tasks.Count, StringFormat={}{0} itens na visao atual}"
                                       Margin="0,5,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Style="{StaticResource FilterChipStyle}" Margin="0,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="SortVariant"
                                                             Width="14"
                                                             Height="14"
                                                             Margin="0,0,6,0"
                                                             Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                    <TextBlock Text="{Binding SelectedGroupingLabel}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="0,0,13,13"
                        ClipToBounds="True">
                    <DataGrid ItemsSource="{Binding TasksView}"
                              SelectedItem="{Binding SelectedTask}"
                              BorderThickness="0"
                              Style="{StaticResource DarkDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource DarkDataGridHeaderStyle}"
                              CellStyle="{StaticResource DarkDataGridCellStyle}"
                              RowStyle="{StaticResource DarkDataGridRowStyle}">
                    <DataGrid.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceRaisedBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="18,12">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding ItemCount, StringFormat=  ({0} acoes)}"
                                                               Margin="8,0,0,0"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </DataGrid.GroupStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="ACAO" Width="2.2*" MinWidth="260">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding What}"
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Why, Converter={StaticResource TaskCategoryConverter}}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="EMPRESA" Binding="{Binding Company}" Width="1.2*" MinWidth="160"/>
                        <DataGridTextColumn Header="QUEM" Binding="{Binding Who}" Width="1*" MinWidth="130"/>
                        <DataGridTextColumn Header="QUANDO" Binding="{Binding When, StringFormat={}{0:dd MMM yyyy}}" Width="1*" MinWidth="120"/>

                        <DataGridTemplateColumn Header="STATUS" Width="1.2*" MinWidth="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                            BorderBrush="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                            BorderThickness="1"
                                            CornerRadius="9"
                                            Padding="11,3"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusTextConverter}}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="PRIORIDADE" Width="1*" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Priority, Converter={StaticResource PriorityColorConverter}}"
                                            BorderBrush="{Binding Priority, Converter={StaticResource PriorityColorConverter}}"
                                            BorderThickness="1"
                                            CornerRadius="9"
                                            Padding="11,3"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityTextConverter}}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="CUSTO" Binding="{Binding HowMuch, StringFormat=R$ {0:N2}}" Width="1*" MinWidth="120"/>

                        <DataGridTemplateColumn Header="ACOES" Width="120" MinWidth="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Command="{Binding DataContext.EditTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ToolbarIconButtonStyle}"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Margin="0,0,7,0"
                                                ToolTip="Editar">
                                            <materialDesign:PackIcon Kind="PencilOutline" Width="16" Height="16"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ToolbarIconButtonStyle}"
                                                Foreground="{DynamicResource DangerBrush}"
                                                ToolTip="Excluir">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
