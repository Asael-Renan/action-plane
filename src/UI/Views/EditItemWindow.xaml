<Window x:Class="FiveW2H.App.UI.Views.EditItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar registro"
        Width="760"
        Height="620"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Icon="/Resources/Icons/app-icon.ico"
        Background="{DynamicResource BackgroundBrush}">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,22">
            <StackPanel>
                <TextBlock Text="Editar registro 5W2H"
                           Style="{StaticResource PageTitleTextStyle}"/>
                <TextBlock Text="{Binding Id, StringFormat=Registro #{0:00000}}"
                           Style="{StaticResource PageSubtitleTextStyle}"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationSummary}"
                           Foreground="{DynamicResource DangerBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding CancelCommand}"
                            Content="Cancelar"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Margin="0,0,10,0"/>
                    <Button Command="{Binding SaveCommand}"
                            Content="Salvar"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Background="{StaticResource SuccessBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22">
                <Border Style="{StaticResource FormCardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="What" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding What, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="Who" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding Who, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="Why" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding Why, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                         Height="92"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalContentAlignment="Top"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="How" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding How, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                         Height="92"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalContentAlignment="Top"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*" MinWidth="148"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*" MinWidth="128"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="Where" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding Where, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="When" Style="{StaticResource FormLabelStyle}"/>
                                <DatePicker MinWidth="0"
                                            HorizontalAlignment="Stretch"
                                            SelectedDate="{Binding When, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="How Much" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding HowMuch, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, StringFormat=N2}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="Status" Style="{StaticResource FormLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Statuses}"
                                          SelectedItem="{Binding SelectedStatus}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="Priority" Style="{StaticResource FormLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Priorities}"
                                          SelectedItem="{Binding SelectedPriority}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                            <TextBlock Text="Detalhes adicionais" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Height="90"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
