<Window x:Class="FiveW2H.App.UI.Views.EditItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="clr-namespace:FiveW2H.App.UI.Views.Components"
        xmlns:helpers="clr-namespace:FiveW2H.App.UI.Helpers"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Editor de acao"
        Width="980"
        Height="780"
        MinWidth="820"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Icon="/Resources/Icons/app-icon.ico"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Border Style="{StaticResource WorkspaceHeaderCardStyle}"
                Padding="0"
                CornerRadius="{StaticResource CornerRadiusLarge}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="24,22,24,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   Style="{StaticResource PageTitleTextStyle}"/>
                        <TextBlock Text="{Binding Subtitle}"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource PageSubtitleTextStyle}"/>
                        <Border Style="{StaticResource ChipBadgeStyle}"
                                HorizontalAlignment="Left"
                                Margin="0,18,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CircleSmall"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="-4,0,4,0"
                                                         Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                <TextBlock Text="{Binding ModeBadgeText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding CancelCommand}"
                            Content="Fechar"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            VerticalAlignment="Top"/>
                </Grid>

                <Border Grid.Row="1"
                        Background="{DynamicResource BorderBrush}"/>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,20,22,18">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="O QUE" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource WrappingTextBoxStyle}"
                                         Text="{Binding What, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="EMPRESA" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource WrappingTextBoxStyle}"
                                         Text="{Binding Company, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="QUEM" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource WrappingTextBoxStyle}"
                                         Text="{Binding Who, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="POR QUE" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                                         Text="{Binding Why, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="COMO" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                                         Text="{Binding How, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.3*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="1.35*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="2.55*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="ONDE" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource WrappingTextBoxStyle}"
                                         Text="{Binding Where, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="QUANDO" Style="{StaticResource FormLabelStyle}"/>
                                <DatePicker MinWidth="0"
                                            SelectedDate="{Binding When, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="CUSTO" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding HowMuch, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, StringFormat=N2}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="6" Style="{StaticResource FormFieldContainerStyle}">
                                <components:PrioritySelector ItemsSource="{Binding Priorities}"
                                                             ItemTemplate="{StaticResource PrioritySelectorItemTemplate}"
                                                             Label="PRIORIDADE"
                                                             SelectedItem="{Binding SelectedPriority}"
                                                             SelectorStyle="{StaticResource SegmentedSelectorStyle}"
                                                             Hint=""/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Style="{StaticResource FormFieldContainerStyle}">
                                <components:PrioritySelector ItemsSource="{Binding Statuses}"
                                                             ItemTemplate="{StaticResource StatusSelectorItemTemplate}"
                                                             Label="STATUS"
                                                             SelectedItem="{Binding SelectedStatus}"
                                                             SelectorStyle="{StaticResource VerticalSegmentedSelectorStyle}"
                                                             Hint=""/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Style="{StaticResource FormFieldContainerStyle}">
                                <TextBlock Text="OBSERVACOES" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                                         MinHeight="130"
                                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="3"
                        Background="{DynamicResource BorderBrush}"/>

                <Border Grid.Row="4"
                        Style="{StaticResource FooterActionBarStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ValidationSummary}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Command="{Binding CancelCommand}"
                                    Content="Cancelar"
                                    Style="{StaticResource TertiaryActionButtonStyle}"
                                    Margin="0,0,10,0"/>
                            <Button Command="{Binding SaveCommand}"
                                    Content="{Binding PrimaryActionText}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
