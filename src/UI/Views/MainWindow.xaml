<Window x:Class="FiveW2H.App.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FiveW2H.App.UI.Converters"
        xmlns:sections="clr-namespace:FiveW2H.App.UI.Views.Sections"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="5W2H - Gestao de Planos de Acao"
        Height="820"
        Width="1460"
        MinHeight="760"
        MinWidth="1240"
        Icon="/Resources/Icons/app-icon.ico"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:StatusTextConverter x:Key="StatusTextConverter"/>
        <local:PriorityTextConverter x:Key="PriorityTextConverter"/>
        <local:TaskCategoryConverter x:Key="TaskCategoryConverter"/>
    </Window.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Padding="18,24,18,18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="5W2H"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryAccentBrush}"/>
                    <TextBlock Text="Gestao de planos de acao"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Command="{Binding OpenDashboardCommand}">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboardOutline"
                                                     Width="16"
                                                     Height="16"
                                                     Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding OpenFilterScreenCommand}">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FormatListBulletedSquare"
                                                     Width="16"
                                                     Height="16"
                                                     Margin="0,0,12,0"/>
                            <TextBlock Text="Acoes" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding OpenCreateScreenCommand}">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PlusBoxOutline"
                                                     Width="16"
                                                     Height="16"
                                                     Margin="0,0,12,0"/>
                            <TextBlock Text="Nova Acao" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CheckForUpdatesCommand}"
                            Style="{StaticResource SidebarNavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Update"
                                                     Width="16"
                                                     Height="16"
                                                     Margin="0,0,12,0"/>
                            <TextBlock Text="Atualizacoes" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3"
                        Style="{StaticResource FormSectionCardStyle}"
                        Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="STATUS"
                                   Style="{StaticResource SectionHeaderTextStyle}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,24,0">
                <Button Command="{Binding ToggleThemeCommand}"
                        Style="{StaticResource ThemeToggleButtonStyle}"
                        ToolTip="Alternar tema claro/escuro">
                    <TextBlock Text="{Binding ThemeToggleGlyph}"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="18"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>

            <TabControl Grid.Row="1"
                        SelectedIndex="{Binding SelectedTabIndex}"
                        Background="{DynamicResource BackgroundBrush}"
                        BorderThickness="0"
                        Padding="0">
                <TabControl.Resources>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                    <Style TargetType="{x:Type TabPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.Resources>

                <TabItem>
                    <sections:DashboardView/>
                </TabItem>

                <TabItem>
                    <sections:TasksView/>
                </TabItem>

                <TabItem>
                    <sections:CreateTaskView/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
