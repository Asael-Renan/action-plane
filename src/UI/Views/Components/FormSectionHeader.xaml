<UserControl x:Class="FiveW2H.App.UI.Views.Components.FormSectionHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <StackPanel>
        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Style="{StaticResource SectionHeaderTextStyle}"/>
        <TextBlock Text="{Binding Description, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Style="{StaticResource FieldHintTextStyle}"/>
    </StackPanel>
</UserControl>
