<UserControl x:Class="FiveW2H.App.UI.Views.Components.ResizableTextArea"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid>
        <TextBox x:Name="Editor"
                 Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                 Height="{Binding EditorHeight, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                 MinHeight="{Binding MinEditorHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 MaxHeight="{Binding MaxEditorHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 Padding="12,10,24,10"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalContentAlignment="Top"
                 VerticalScrollBarVisibility="Auto"/>

        <Thumb HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,8,8"
               Cursor="SizeNS"
               DragDelta="OnResizeThumbDragDelta">
            <Thumb.Template>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Width="16"
                            Height="16"
                            Background="Transparent">
                        <materialDesign:PackIcon Kind="DragVerticalVariant"
                                                 Width="12"
                                                 Height="12"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource TextMutedBrush}"
                                                 Opacity="0.9"/>
                    </Border>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</UserControl>
